<?xml version="1.0"?>

<robot name="pandalite">
    <mujoco>
        <compiler discardvisual="false" strippath="false" balanceinertia="true"/>
    </mujoco>
    <!-- Materials -->
    <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
    </material>
    <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
    </material>

    <!-- Base Link-->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.06" length="0.08"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <inertial>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.002" ixy="0" ixz="0"
               iyy="0.002" iyz="0"
               izz="0.002"/>
        </inertial>
    </link>

    <!-- Joint 1 (Revolute joint between base_link and link_1) -->
     <joint name="base_link_1_joint" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" velocity="2.5" effort="10.0"/>
     </joint>

    <!-- Link 1 (Shorter cylinder above base_link) -->
     <link name="link_1">
        <visual>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <geometry>
              <cylinder radius="0.04" length="0.06"/>
            </geometry>
            <material name="orange"/>
          </visual>
          <inertial>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <mass value="0.5"/>
            <inertia ixx="0.0005" ixy="0" ixz="0"
                     iyy="0.0005" iyz="0"
                     izz="0.0005"/>
          </inertial>
     </link>

     <!-- Joint 2 (Revolute joint between link_1 and link_2, Y-axis)-->
      <joint name="link_1_2_joint" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="0 0 0.06" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.5"/>
      </joint>

     <!-- Link 2 (Upper arm, extends along X-axis)-->
     <link name="link_2">
        <visual>
            <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.18"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <inertial>
            <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
            <mass value="0.4"/>
            <inertia ixx="0.0005" ixy="0" ixz="0"
                     iyy="0.001" iyz="0"
                     izz="0.001"/>
        </inertial>
     </link> 

     <!-- Joint 3 (revolute joint between link_2 and link_3, x-axis-->
      <joint name="link_2_3_joint" type="revolute">
        <parent link="link_2"/>
        <child link="link_3"/>
        <origin xyz="0.18 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.5" upper="2.5" effort="8.0" velocity="2.5"/>
      </joint>

     <!-- Link 3 (forearm, extends along x-axis) -->
      <link name="link_3">
        <visual>
            <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
            <geometry>
                <cylinder radius="0.022" length="0.18"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <inertial>
            <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
            <mass value="0.3"/>
            <inertia ixx="0.0004" ixy="0" ixz="0"
                     iyy="0.0008" iyz="0"
                     izz="0.0008"/>
        </inertial>
      </link>

      <!-- Joint 4 (revolute joint between link_3 and link_4, z-axis) -->
      <joint name="link_3_4_joint" type="revolute">
        <parent link="link_3"/>
        <child link="link_4"/>
        <origin xyz="0.18 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-3.14" upper="3.14" effort="5.0" velocity="3.0"/>
      </joint>

      <!-- Link 4 (wrist housing (box for visual) -->
      <link name="link_4">
        <visual>
            <origin xyz="0.02 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.04 0.05 0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <inertial>
            <origin xyz="0.02 0 0" rpy="0 0 0"/>
            <mass value="0.15"/>
            <inertia ixx="0.00005" ixy="0" ixz="0"
                     iyy="0.00004" iyz="0"
                     izz="0.00005"/>
          </inertial>
      </link>

      <!-- Joint 5 (revolute joint between link_4 and link_5, y-axis)-->
       <joint name="link_4_5_joint" type="revolute">
            <parent link="link_4"/>
            <child link="link_5"/>
            <origin xyz="0.04 0 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit lower="-2.0" upper="2.0" effort="4" velocity="3"/>
       </joint>

      <!-- Link 5 (wrist pitch housing)-->
       <link name="link_5">
        <visual>
            <origin xyz="0.02 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.04 0.03 0.05"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <inertial>
            <origin xyz="0.02 0 0" rpy="0 0 0"/>
            <mass value="0.12"/>
            <inertia ixx="0.00004" ixy="0" ixz="0"
                     iyy="0.00005" iyz="0"
                     izz="0.00004"/>
        </inertial>
       </link>

       <!-- Joint 6 (wrist yaw), revolute, z-axis-->
        <joint name="wrist_yaw" type="revolute">
            <parent link="link_5"/>
            <child link="link_6"/>
            <origin xyz="0.04 0 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-3.14" upper="3.14" effort="3.0" velocity="3.0"/>
        </joint>

       <!-- Link 6 (wrist yaw housing)-->
       <link name="link_6">
            <visual>
                <origin xyz="0.02 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.04 0.05 0.03"/>
                </geometry>
                <material name="blue"/>
            </visual>
            <inertial>
                <origin xyz="0.02 0 0" rpy="0 0 0"/>
                <mass value="0.1"/>
                <inertia ixx="0.00003" ixy="0" ixz="0"
                         iyy="0.00004" iyz="0"
                         izz="0.00003"/>
            </inertial>
       </link>

        <!-- Tool tip frame (fixed, no DOF)               -->
        
        <joint name="tool_tip_joint" type="fixed">
            <parent link="link_6"/>
            <child link="tool_tip"/>
            <origin xyz="0.04 0 0" rpy="0 0 0"/>
        </joint>

        <link name="tool_tip">
            <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="1e-6" ixy="0" ixz="0"
                    iyy="1e-6" iyz="0"
                    izz="1e-6"/>
            </inertial>
        </link>

        <ros2_control name="PandaliteSystem" type="system">
            <hardware>
                <plugin>pandalite_mujoco_hw/PandaliteMujocoSystem</plugin>
            </hardware>
            <joint name="base_link_1_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
            <joint name="link_1_2_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
            <joint name="link_2_3_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
            <joint name="link_3_4_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
            <joint name="link_4_5_joint">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
            <joint name="wrist_yaw">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
                <state_interface name="effort"/>
            </joint>
        </ros2_control>
</robot>